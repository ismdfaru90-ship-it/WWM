{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksJson": "/workspace/WWM/nixpacks.toml"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "startCommand": "uvicorn openhands.app_server.app:app --host 0.0.0.0 --port 3000"
  },
  "env": {
    "LLM_BASE_URL": "https://openrouter.ai/api/v1",
    "LLM_MODEL": "openrouter/auto",
    "PORT": "3000"
  }
}
