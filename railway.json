{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "noCache": true
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "healthcheckPath": "/health",
    "startCommand": "cd /app && RUNTIME=local uvicorn openhands.app_server.app:app --host 0.0.0.0 --port 3000"
  },
  "environment": {
    "RUNTIME": "local"
  }
}
